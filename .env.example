# Portfolio - Environment Variables
# Copy this file to .env.local and fill in the values

# Personal Contact (optional - for backend/API integrations)
# NEXT_PUBLIC_CONTACT_EMAIL=your.email@example.com
# NEXT_PUBLIC_CONTACT_PHONE=+1-234-567-8900

# Social URLs (configured in src/config/social.ts)
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your-profile
# NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username

# Site Configuration
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# NEXT_PUBLIC_RESUME_URL=/resume.pdf
