# Portfolio - Environment Variables
# Copy this file to .env.local and fill in the values

# SMTP Email Configuration (required for contact form)
# For Gmail: enable 2FA, generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password-here
CONTACT_EMAIL=where@to.send.form.submissions

# Site Configuration
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
